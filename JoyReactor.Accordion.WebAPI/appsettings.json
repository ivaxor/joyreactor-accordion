{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "ElasticsearchUri": ""
  },
  "AuthSettings": {
    "ApiKeys": []
  },
  "TelegramBotSettings": {
    "ChatId": null,
    "Token": null
  },
  "AllowedHosts": "*",
  "ApiClientSettings": {
    "SubsequentCallDelay": "00:00:05.000000",
    "RetryDelay": "00:01:00.000000",
    "MaxRetryAttempts": 3
  },
  "MediaSettings": {
    "CdnHostNames": [
      "https://img0.joyreactor.cc",
      "https://img1.joyreactor.cc",
      "https://img2.joyreactor.cc",
      "https://img10.joyreactor.cc"
    ],
    "BatchSize": 5,
    "SubsequentBatchDelay": "00:00:10.000000",
    "SubsequentCallDelay": "00:00:01.000000",
    "RetryDelay": "00:00:10.000000",
    "MaxRetryAttempts": 3,
    "ResizedSize": 224
  },
  "OnnxSettings": {
    "ModelPath": "./Onnx/clip-ViT-B-32-vision.onnx",
    "InputName": "pixel_values",
    "InputSize": 224,
    "OutputName": "image_embeds",
    "OutputSize": 512,
    "UseCpu": true,
    "UseCuda": false,
    "UseRocm": false,
    "UseOpenVino": false,
    "DeviceId": "0"
  },
  "PostgreSqlSettings": {
    "ConnectionString": "Host=127.0.0.1;Port=5432;User ID=user;Password=password;Database=database;Pooling=true;"
  },
  "QdrantSettings": {
    "Host": "127.0.0.1",
    "Port": 6334,
    "CollectionName": "images",
    "CollectionVectorSize": 512
  },
  "RabbitMqSettings": {
    "Host": null,
    "UserName": null,
    "Password": null
  },
  "BackgroundServiceSettings": {
    "ServiceNamesEnabled": {
      "PostPictureCreatedCatchUp": true,
      "VectorCreatedCatchUp": true,

      "SqlVectorCleaner": true,
      "TelegramBotReceiver": true,

      "ChangedApiPostPublisher": true,
      "CrawlerApiPostPublisher": true,

      "EmptyPostEmbedsFixer": true,
      "RootTagsCrawler": false,
      "TagSubTagsCrawler": false
    }
  },
  "ConsumersSettings": {
    "ConsumersEnabled": {
      "ApiPostCreatedConsumer": true,
      "PostPictureCreatedConsumer": true,
      "VectorCreatedConsumer": true,
      "VoteCreatedConsumer": true
    }
  },
  "RateLimiterSettings": {
    "PermitLimit": 50,
    "Window": "00:01:0.000000"
  }
}